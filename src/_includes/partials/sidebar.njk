<aside class="sidebar" id="sidebar">
  <div class="sidebar-header">
    <span class="site-name">santi.wtf</span>
    <button class="sidebar-close" id="sidebar-close" aria-label="close menu">&times;</button>
  </div>

  <nav class="file-tree" aria-label="site navigation">
    <a href="/" class="tree-item{% if page.url === '/' %} active{% endif %}">
      <span class="tree-icon">📄</span> readme
    </a>
    <a href="/notes/" class="tree-item folder{% if '/notes/' in page.url %} active{% endif %}">
      <span class="tree-icon">📁</span> notes
    </a>
    <a href="/newsletter/" class="tree-item{% if page.url === '/newsletter/' %} active{% endif %}">
      <span class="tree-icon">📁</span> newsletter
    </a>
    <a href="/photos/" class="tree-item{% if '/photos/' in page.url %} active{% endif %}">
      <span class="tree-icon">📁</span> photos
    </a>
  </nav>

  <div class="sidebar-footer">
    <button class="theme-toggle" id="theme-toggle" aria-label="toggle theme">
      <span class="theme-icon"></span>
    </button>
  </div>
</aside>

<button class="sidebar-toggle" id="sidebar-toggle" aria-label="open menu">
  <span></span>
  <span></span>
  <span></span>
</button>
