<aside class="sidebar" id="sidebar">
  <div class="sidebar-header">
    <a href="/" class="site-name">santi villanueva</a>
    <div class="sidebar-actions">
      <button class="sidebar-action-btn" id="toggle-folders" aria-label="collapse all folders" title="collapse/expand all">
        <svg class="sidebar-action-icon"><use href="#icon-collapse"/></svg>
      </button>
      <button class="sidebar-action-btn" id="hide-sidebar" aria-label="hide sidebar" title="hide sidebar">
        <svg class="sidebar-action-icon"><use href="#icon-sidebar-hide"/></svg>
      </button>
      <button class="sidebar-close" id="sidebar-close" aria-label="close menu">&times;</button>
    </div>
  </div>

  <nav class="file-tree" id="file-tree" aria-label="site navigation">
    <a href="/" class="tree-item{% if page.url === '/' %} active{% endif %}">
      <svg class="tree-icon"><use href="#icon-note"/></svg> readme
    </a>

    <details class="tree-folder"{% if '/notes/' in page.url %} open{% endif %}>
      <summary class="tree-item folder">
        <svg class="tree-icon"><use href="#icon-folder"/></svg> notes
      </summary>
      <div class="tree-children">
        {% for note in collections.notesByTitle %}
        <a href="{{ note.url }}" class="tree-item child{% if note.url === page.url %} active{% endif %}" data-title="{{ note.data.title | lower }}">
          <svg class="tree-icon"><use href="#icon-note"/></svg> {{ note.data.title }}
        </a>
        {% endfor %}
      </div>
    </details>

    <details class="tree-folder"{% if '/newsletter/' in page.url %} open{% endif %}>
      <summary class="tree-item folder">
        <svg class="tree-icon"><use href="#icon-folder"/></svg> newsletter
      </summary>
      <div class="tree-children">
        <a href="/newsletter/" class="tree-item child{% if page.url === '/newsletter/' %} active{% endif %}" data-title="subscribe">
          <svg class="tree-icon"><use href="#icon-file"/></svg> subscribe
        </a>
      </div>
    </details>

    <details class="tree-folder"{% if '/photos/' in page.url %} open{% endif %}>
      <summary class="tree-item folder">
        <svg class="tree-icon"><use href="#icon-folder"/></svg> photos
      </summary>
      <div class="tree-children">
        {% if collections.photos | length %}
          {% for photo in collections.photos %}
          <a href="{{ photo.url }}" class="tree-item child{% if photo.url === page.url %} active{% endif %}" data-title="{{ photo.data.title | lower }}">
            <svg class="tree-icon"><use href="#icon-image"/></svg> {{ photo.data.title }}
          </a>
          {% endfor %}
        {% else %}
          <span class="tree-item child dim">coming soon</span>
        {% endif %}
      </div>
    </details>
  </nav>

  <div class="sidebar-search" id="sidebar-search">
    <svg class="search-input-icon"><use href="#icon-search"/></svg>
    <input type="text" class="search-input" id="sidebar-search-input" placeholder="filter notes..." autocomplete="off" spellcheck="false">
  </div>
</aside>

<!-- mobile overlay -->
<div class="sidebar-overlay" id="sidebar-overlay"></div>
