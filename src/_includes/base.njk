<!doctype html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% if title %}{{ title }} — {{ site.title }}{% else %}{{ site.title }}{% endif %}</title>
  <meta name="description" content="{{ description or site.description }}">

  <!-- prevent flash of wrong theme -->
  <script>
    (function() {
      var saved = localStorage.getItem('theme');
      var preferred = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      document.documentElement.setAttribute('data-theme', saved || preferred);
    })();
  </script>

  <link rel="preconnect" href="https://rsms.me/">
  <link rel="stylesheet" href="https://rsms.me/inter/inter.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="alternate" type="application/rss+xml" title="{{ site.title }}" href="/feed.xml">
</head>
<body>
  {% include "partials/icons.njk" %}
  <div class="layout" id="layout">
    {% include "partials/sidebar.njk" %}

    <div class="editor">
      <header class="editor-header">
        <div class="editor-header-left">
          <button class="sidebar-toggle" id="sidebar-toggle" aria-label="open menu">
            <svg class="header-icon"><use href="#icon-sidebar-show"/></svg>
          </button>
          <span class="editor-filename">{{ title or "readme" }}</span>
        </div>
        <div class="editor-actions">
          <button class="theme-toggle" id="theme-toggle" aria-label="toggle theme">
            <svg class="header-icon theme-icon-sun"><use href="#icon-sun"/></svg>
            <svg class="header-icon theme-icon-moon"><use href="#icon-moon"/></svg>
          </button>
        </div>
      </header>

      <main class="editor-content">
        {{ content | safe }}
      </main>

      <footer class="editor-statusbar">
        <span class="status-left">
          <svg class="status-icon"><use href="#icon-calendar"/></svg>
          {% if updated %}{{ updated | readableDateTime }}{% elif date %}{{ date | readableDateTime }}{% else %}—{% endif %}
        </span>
        <span class="status-right">santi.wtf</span>
      </footer>
    </div>
  </div>

  <script src="/js/theme.js"></script>
  <script src="/js/search.js"></script>
</body>
</html>
