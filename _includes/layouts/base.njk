    <symbol id="image" viewBox="0 0 256 256"><path d="M216,40H40A16,16,0,0,0,24,56V200a16,16,0,0,0,16,16H216a16,16,0,0,0,16-16V56A16,16,0,0,0,216,40Zm0,16V158.75l-26.07-26.06a16,16,0,0,0-22.63,0l-20,20-44-44a16,16,0,0,0-22.62,0L40,149.37V56ZM40,172l52-52,80,80H40Zm176,28H194.63l-36-36,20-20L216,181.38V200ZM144,100a12,12,0,1,1,12,12A12,12,0,0,1,144,100Z"/></symbol>
    <symbol id="envelope" viewBox="0 0 256 256"><path d="M224,48H32a8,8,0,0,0-8,8V192a16,16,0,0,0,16,16H216a16,16,0,0,0,16-16V56A8,8,0,0,0,224,48ZM203.43,64,128,133.15,52.57,64ZM216,192H40V74.19l82.59,75.71a8,8,0,0,0,10.82,0L216,74.19V192Z"/></symbol>
  </svg>

  <div class="file">
    <header class="file-header">
      <button class="btn btn-icon title-sidebar-btn toggle-sidebar" aria-label="toggle sidebar">
        <svg width="18" height="18"><use href="#sidebar-simple"></use></svg>
      </button>
      <h1>{{ title or "readme" }}</h1>
      <div class="file-header-actions">
        <button class="btn btn-icon btn-subtle palette-trigger" aria-label="search" data-open-palette>
          <svg width="18" height="18"><use href="#magnifying-glass"></use></svg>
        </button>
        {% if page.url.startsWith('/newsletter/') and page.url != '/newsletter/' %}
          {% set nav = page | getPrevNext(collections.newsletter) %}
        {% elif page.url.startsWith('/photos/') and page.url != '/photos/' %}
          {% set nav = page | getPrevNext(collections.photos) %}
        {% else %}
          {% set nav = page | getPrevNext(collections.notesByTitle) %}
        {% endif %}
        {% if nav.prev %}
        <a href="{{ nav.prev.url }}" class="btn btn-icon" aria-label="previous note" title="{{ nav.prev.data.title }}">
          <svg width="18" height="18"><use href="#caret-left"></use></svg>
        </a>
        {% endif %}
        {% if nav.next %}
        <a href="{{ nav.next.url }}" class="btn btn-icon" aria-label="next note" title="{{ nav.next.data.title }}">
          <svg width="18" height="18"><use href="#caret-right"></use></svg>
        </a>
        {% endif %}
        <button class="btn btn-icon" id="theme-toggle" aria-label="toggle theme">
          <svg width="18" height="18" class="theme-icon-sun"><use href="#sun"></use></svg>
          <svg width="18" height="18" class="theme-icon-moon"><use href="#moon"></use></svg>
        </button>
      </div>
    </header>

    <main class="{{ template or 'note' }}">
      {{ content | safe }}
    </main>

    {% include "footer.njk" %}
  </div>

  <div class="palette" id="palette" hidden>
    <div class="palette-backdrop" data-close-palette></div>
    <div class="palette-modal">
      <div class="palette-input-wrapper">
        <svg width="16" height="16"><use href="#magnifying-glass"></use></svg>
        <input type="text" class="palette-input" id="palette-input" placeholder="search notes, newsletter, photos..." autocomplete="off" spellcheck="false" autocapitalize="off">
        <kbd>esc</kbd>
      </div>
      <ul class="palette-results" id="palette-results"></ul>
      <div class="palette-footer">
        <span><kbd>↑↓</kbd> navigate</span>
        <span><kbd>↵</kbd> open</span>
        <span><kbd>esc</kbd> close</span>
      </div>
    </div>
  </div>

  <script>
    // --- theme toggle ---
    (function() {
      const toggle = document.getElementById('theme-toggle');
      if (!toggle) return;
      toggle.addEventListener('click', () => {
        const current = document.documentElement.style.colorScheme;
        const next = current === 'dark' ? 'light' : 'dark';
        document.documentElement.style.colorScheme = next;
        localStorage.setItem('theme', next);
      });

      const saved = localStorage.getItem('theme');
      const preferred = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      document.documentElement.style.colorScheme = saved || preferred;
    })();

    // --- sidebar ---
    (function() {
      const sidebar = document.querySelector('.navigator');
      if (!sidebar) return;

      const breakpoint = 768;
      function isSmallScreen() { return window.innerWidth < breakpoint; }

      function restoreSidebarState(skipTransition) {
        if (skipTransition) {
          sidebar.classList.add('no-transition');
          document.querySelectorAll('.file, .file-header, .content-footer').forEach(el => el && el.classList.add('no-transition'));
        }
        sidebar.classList.remove('open', 'closed');
        if (isSmallScreen()) {
          if (localStorage.getItem('sidebarOpenSmall') !== 'true') {
            // stay closed (default on mobile)
          } else {
            sidebar.classList.add('open');
          }
        } else {
          if (localStorage.getItem('sidebarClosedLarge') === 'true') {
            sidebar.classList.add('closed');
          }
        }
        if (skipTransition) {
          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              sidebar.classList.remove('no-transition');
              document.querySelectorAll('.file, .file-header, .content-footer').forEach(el => el && el.classList.remove('no-transition'));
            });
          });
        }
      }

      restoreSidebarState(true);

      document.querySelectorAll('.toggle-sidebar').forEach(btn => {
        btn.addEventListener('click', () => {
          if (isSmallScreen()) {
            sidebar.classList.toggle('open');
            localStorage.setItem('sidebarOpenSmall', sidebar.classList.contains('open'));
          } else {
            sidebar.classList.toggle('closed');
            localStorage.setItem('sidebarClosedLarge', sidebar.classList.contains('closed'));
          }
        });
      });

      const toggleDetails = document.querySelector('.toggle-details');
      if (toggleDetails) {
        toggleDetails.addEventListener('click', () => {
          const details = sidebar.querySelectorAll('details');
          const allOpen = [...details].every(d => d.open);
          details.forEach(d => d.open = !allOpen);
        });
      }

      let wasSmall = isSmallScreen();
      window.addEventListener('resize', () => {
        const nowSmall = isSmallScreen();
        if (wasSmall !== nowSmall) { restoreSidebarState(); wasSmall = nowSmall; }
      });

      // close sidebar on mobile link click
      sidebar.addEventListener('click', (e) => {
        if (e.target.closest('a') && isSmallScreen()) {
          sidebar.classList.remove('open');
          localStorage.setItem('sidebarOpenSmall', 'false');
        }
      });

      // close sidebar on backdrop click (mobile)
      document.querySelectorAll('[data-close-sidebar]').forEach(el => {
        el.addEventListener('click', () => {
          sidebar.classList.remove('open');
          localStorage.setItem('sidebarOpenSmall', 'false');
        });
      });

      // prevent summary click from toggling details when clicking the link
      document.querySelectorAll('.directory summary').forEach(summary => {
        summary.addEventListener('click', (e) => {
          if (e.target.tagName === 'A' || e.target.closest('a')) {
            e.preventDefault();
            const link = e.target.tagName === 'A' ? e.target : e.target.closest('a');
            window.location.href = link.href;
          }
        });
      });
    })();

    // --- command palette ---
    (function() {
      const palette = document.getElementById('palette');
      const input = document.getElementById('palette-input');
      const results = document.getElementById('palette-results');
      if (!palette || !input || !results) return;

      let items = null;
      let filtered = [];
      let selected = 0;

      async function loadIndex() {
        if (items) return items;
        try {
          const res = await fetch('/search-index.json');
          const data = await res.json();
          items = data.items || [];
        } catch (e) {
          items = [];
        }
        return items;
      }

      function open() {
        palette.hidden = false;
        document.body.style.overflow = 'hidden';
        loadIndex().then(() => {
          input.value = '';
          filter('');
          input.focus();
        });
      }

      function close() {
        palette.hidden = true;
        document.body.style.overflow = '';
        input.value = '';
      }

      function iconForSection(section) {
        if (section === 'newsletter') return 'envelope';
        if (section === 'photos') return 'image';
        return 'note';
      }

      function escapeHtml(s) {
        return s.replace(/[&<>"']/g, c => ({
          '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
        })[c]);
      }

      function filter(query) {
        const q = query.toLowerCase().trim();
        if (!q) {
          filtered = (items || []).slice(0, 50);
        } else {
          filtered = (items || [])
            .map(it => {
              const idx = it.title.toLowerCase().indexOf(q);
              return idx === -1 ? null : Object.assign({}, it, { _score: idx });
            })
            .filter(Boolean)
            .sort((a, b) => a._score - b._score)
            .slice(0, 50);
        }
        selected = 0;
        render();
      }

      function render() {
        if (!filtered.length) {
          results.innerHTML = '<li class="palette-empty">no results</li>';
          return;
        }
        results.innerHTML = filtered.map((it, i) =>
          '<li class="palette-result' + (i === selected ? ' selected' : '') +
          '" data-url="' + it.url + '" data-i="' + i + '">' +
          '<svg width="16" height="16"><use href="#' + iconForSection(it.section) + '"></use></svg>' +
          '<span class="palette-result-title">' + escapeHtml(it.title) + '</span>' +
          '<span class="palette-result-section">' + it.section + '</span>' +
          '</li>'
        ).join('');
      }

      function move(delta) {
        if (!filtered.length) return;
        selected = (selected + delta + filtered.length) % filtered.length;
        render();
        const el = results.querySelector('.selected');
        if (el) el.scrollIntoView({ block: 'nearest' });
      }

      function activate() {
        const item = filtered[selected];
        if (!item) return;
        close();
        window.location.href = item.url;
      }

      document.addEventListener('keydown', (e) => {
        const isShortcut = (e.metaKey || e.ctrlKey) && (e.key === 'k' || e.key === 'p' || e.key === 'K' || e.key === 'P');
        if (isShortcut) {
          e.preventDefault();
          if (palette.hidden) open(); else close();
          return;
        }
        if (palette.hidden) return;
        if (e.key === 'Escape') { e.preventDefault(); close(); }
        if (e.key === 'ArrowDown') { e.preventDefault(); move(1); }
        if (e.key === 'ArrowUp') { e.preventDefault(); move(-1); }
        if (e.key === 'Enter') { e.preventDefault(); activate(); }
      });

      input.addEventListener('input', () => filter(input.value));

      results.addEventListener('mousemove', (e) => {
        const li = e.target.closest('.palette-result');
        if (!li) return;
        const i = parseInt(li.dataset.i, 10);
        if (i !== selected) { selected = i; render(); }
      });

      results.addEventListener('click', (e) => {
        const li = e.target.closest('.palette-result');
        if (!li) return;
        selected = parseInt(li.dataset.i, 10);
        activate();
      });

      document.querySelectorAll('[data-open-palette]').forEach(btn => {
        btn.addEventListener('click', () => { open(); });
      });
      document.querySelectorAll('[data-close-palette]').forEach(el => {
        el.addEventListener('click', close);
      });
    })();

    // --- sidebar filter ---
    (function() {
      const input = document.querySelector('.filter-input');
      const directory = document.querySelector('.directory');
      if (!input || !directory) return;

      input.addEventListener('input', (e) => {
        const query = e.target.value.toLowerCase().trim();

        if (!query) {
          directory.classList.remove('searching');
          directory.querySelectorAll('li, details').forEach(el => el.classList.remove('filtered-out'));
          return;
        }

        directory.classList.add('searching');
        directory.querySelectorAll('details').forEach(d => d.open = true);

        let hasResults = false;
        directory.querySelectorAll('.list-item a').forEach(link => {
          const li = link.closest('li');
          if (!li || link.closest('summary')) return;
          const match = link.textContent.toLowerCase().includes(query);
          li.classList.toggle('filtered-out', !match);
          if (match) hasResults = true;
        });

        directory.querySelectorAll('details').forEach(d => {
          const visible = d.querySelectorAll('li:not(.filtered-out)').length;
          d.classList.toggle('filtered-out', visible === 0);
        });
      });
    })();
  </script>
<script>
document.querySelectorAll('.content-area a[href^="http"]').forEach(a => {
  a.setAttribute('target', '_blank');
  a.setAttribute('rel', 'noopener');
});
</script>
</body>
</html>
