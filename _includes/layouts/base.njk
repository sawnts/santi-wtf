<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% if title %}{{ title }} · santi.wtf{% else %}santi.wtf{% endif %}</title>
  <meta name="description" content="{{ description or 'santi\'s digital garden — ideas growing in public.' }}">
  <meta name="color-scheme" content="light dark">

  <meta property="og:type" content="website">
  <meta property="og:url" content="https://santi.wtf{{ page.url }}">
  <meta property="og:title" content="{% if title %}{{ title }} · santi.wtf{% else %}santi.wtf{% endif %}">
  <meta property="og:description" content="{{ description or 'santi\'s digital garden — ideas growing in public.' }}">
  <meta property="og:image" content="https://santi.wtf/og.png">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:image" content="https://santi.wtf/og.png">

  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="preload" href="/fonts/MonaspaceKryptonVar.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/fonts/MonaspaceNeonVar.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="stylesheet" href="/css/base.css">
  <link rel="alternate" type="application/rss+xml" title="santi.wtf" href="/feed.xml">
</head>
<body>

